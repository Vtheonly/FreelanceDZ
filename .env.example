# ============================================================
# DZ Sales Intelligence - Environment Configuration
#
# Copy this file to `.env` and replace the placeholder values
# with your own credentials.
# ============================================================

# ============================================================
# LLM Provider
# ============================================================

# Choose one provider:
#   - groq
#   - openrouter
LLM_PROVIDER=groq

# Groq
# Get your API key from: https://console.groq.com/
LLM_API_KEY=your_groq_api_key_here
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# ------------------------------------------------------------
# OpenRouter (Alternative)
# Uncomment these if using OpenRouter instead.
# Get your API key from: https://openrouter.ai/keys
# ------------------------------------------------------------

# LLM_PROVIDER=openrouter
# LLM_API_KEY=your_openrouter_api_key_here
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ============================================================
# Operational
# ============================================================

LOG_LEVEL=INFO
MAX_CONCURRENT_REQUESTS=2
RATE_LIMIT_DELAY_SECONDS=3.0
LLM_MAX_RETRIES=4
LLM_TIMEOUT_SECONDS=45

# Cache LLM responses to reduce API usage
ENABLE_LLM_CACHE=true
CACHE_DIR=./data/cache

# ============================================================
# Scraping
# ============================================================

SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_USER_AGENT=DZ-SalesIntel/1.0 (+https://github.com/your-username/your-repository)

ENABLE_OVERPASS_SCRAPER=true
ENABLE_DDG_SCRAPER=true
ENABLE_MOCK_SCRAPER=true

# ============================================================
# Storage
# ============================================================

DATABASE_PATH=./data/leads.db
EXPORT_DIR=./data/exports

# ============================================================
# Pipeline
# ============================================================

DEFAULT_WILAYA=Algiers
DEFAULT_COUNTRY=Algeria
DEFAULT_QUERY_LIMIT=10
TOP_LEADS_N=20

# ============================================================
# API / Dashboard
# ============================================================

API_HOST=0.0.0.0
API_PORT=8080
ENABLE_DASHBOARD=true